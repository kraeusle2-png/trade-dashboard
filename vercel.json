{
  "version": 2,
  "builds": [
    {
      "src": "api/analyse.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/analyse", "dest": "/api/analyse.py" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
